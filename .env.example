PROJECT_NAME=Tourism App API
VERSION=0.1.0
AI_CORE_BASE_URL=http://localhost:8001
AI_CORE_TIMEOUT=300
AI_CORE_USE_MOCK=false
QUESTION_POOL_PATH=data/question_pool.json
GOONG_API_KEY=
GOONG_BASE_URL=https://rsapi.goong.io
GOONG_TIMEOUT=10
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_TIMEOUT=10

# Database. Required for auth/register and persisted backend data.
# Leave the placeholder value and AUTO_POSTGRES=1 to let scripts/vm_start.sh
# create a local PostgreSQL database and replace DATABASE_URL automatically.
DATABASE_URL=postgresql+asyncpg://bevietnam:change-me@localhost:5432/bevietnam
AUTO_POSTGRES=1
POSTGRES_DB=bevietnam
POSTGRES_USER=bevietnam
POSTGRES_PASSWORD=

# Backend auth. Override SECRET_KEY in every non-local environment.
SECRET_KEY=dev-only-change-me-in-production-32-bytes-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI Core ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
LLM_PROVIDER=vllm
VLLM_BASE_URL=https://api.iamphuckhang.dev/v1
VLLM_MODEL=qwen2.5-14b-instruct
VLLM_API_KEY=

# Embeddings and cultural vector retrieval.
HF_TOKEN=your-huggingface-token
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PATH=/tmp/bevietnam-qdrant
QDRANT_CLUSTER_ENDPOINT=
QDRANT_API_KEY=
QDRANT_COLLECTION=cultural_knowledge

# VM runner defaults. Override per command when needed.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
AI_HOST=0.0.0.0
AI_PORT=8001
RUN_MIGRATIONS=1
INSTALL_DEPS=auto
AUTO_APT_INSTALL=1
START_VLLM=0
START_VLLM_TUNNEL=0

# Map backend proxy — Android reads style URL from this endpoint
# Should be the public URL where the backend API is hosted
PUBLIC_API_BASE_URL=https://api.iamphuckhang.dev/api/v1
# Goong MapTiles key (for map tile rendering, separate from geocoding)
GOONG_MAPTILES_KEY=
