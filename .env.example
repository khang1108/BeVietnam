PROJECT_NAME=Tourism App API
VERSION=0.1.0
AI_CORE_BASE_URL=http://localhost:8001
AI_CORE_TIMEOUT=10
AI_CORE_USE_MOCK=false
QUESTION_POOL_PATH=data/question_pool.json
GOONG_API_KEY=
GOONG_BASE_URL=https://rsapi.goong.io
GOONG_TIMEOUT=10

# ── AI Core ───────────────────────────────────────────────────────────────────
LLM_PROVIDER=vllm
VLLM_BASE_URL=https://api.iamphuckhang.dev/v1
VLLM_MODEL=qwen2.5-14b-instruct
VLLM_VISION_BASE_URL=https://api.iamphuckhang.dev/vision/v1
VLLM_VISION_MODEL=qwen2.5-vl-7b
VLLM_API_KEY=
VLLM_TIMEOUT_SECONDS=90

# Qdrant Cloud. Leave these empty and set QDRANT_PATH for embedded local Qdrant.
QDRANT_CLUSTER_ENDPOINT=
QDRANT_API_KEY=
QDRANT_COLLECTION=cultural_knowledge
QDRANT_PATH=
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embeddings for Qdrant seeding/querying.
HF_TOKEN=

# LangSmith tracing. Do not expose these to web/mobile clients.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=BeVietnam AI
