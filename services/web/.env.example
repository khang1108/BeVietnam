# BeVietnam web — public runtime config (inlined into the browser bundle at build time).
# Copy to .env.local for local dev. In CI these come from GitHub secrets/vars.

# Backend API base (FastAPI). No trailing slash beyond /api/v1.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Goong "Maptiles" key (NOT the REST API key) — required for the explore map.
NEXT_PUBLIC_GOONG_API_KEY=your_goong_maptiles_key
