# BeVietnam backend — copy to services/backend/.env

# Async Postgres (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bevietnam

# JWT auth — set a strong random SECRET_KEY in production
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# MinIO / S3-compatible storage for capture media
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# AI Core
AI_CORE_BASE_URL=http://ai-core:8001
AI_CORE_USE_MOCK=true
