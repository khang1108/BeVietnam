# BeVietnam backend — copy to services/backend/.env (gitignored).

# Async Postgres (asyncpg driver — note the +asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bevietnam

# JWT auth — set a strong random SECRET_KEY (32+ bytes) in production
SECRET_KEY=change-me-in-production-32-bytes-minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# MinIO / S3-compatible storage for capture media
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bevietnam-captures

# AI service
AI_CORE_BASE_URL=http://127.0.0.1:8001
AI_CORE_USE_MOCK=true

# Optional context enrichment
GOONG_API_KEY=
OPENWEATHER_API_KEY=
