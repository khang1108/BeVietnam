#!/usr/bin/env bash
# One-shot local-only VM setup for BeVietnam.
#
# Workflow:
#   1. Copy this file to scripts/vm_full_setup.local.sh.
#   2. Fill the secret values in the CONFIG section below.
#   3. scp this one file to the Thundercompute VM.
#   4. Run: bash scripts/vm_full_setup.local.sh
#
# The real scripts/vm_full_setup.local.sh file is gitignored.

set -euo pipefail

# ── CONFIG: edit these locally before scp ─────────────────────────────────────
PROJECT_ROOT="${PROJECT_ROOT:-$HOME/beVietnam}"

# Backend/API public tunnel. Default exposes Backend on the public hostname.
CF_HOSTNAME="api.iamphuckhang.dev"
CF_TUNNEL_ID=""
CF_ACCOUNT_TAG=""
CF_TUNNEL_SECRET=""
CLOUDFLARED_SERVICE_URL="http://127.0.0.1:8000"
CLOUDFLARED_ROUTE_VLLM_PATHS="0"  # 1 = also expose /v1/* to local vLLM

# Backend secrets/integrations.
SECRET_KEY=""          # blank = generated from existing .env or new random value
GOONG_API_KEY=""
OPENWEATHER_API_KEY=""

# PostgreSQL. Blank POSTGRES_PASSWORD = use existing .env value or generate.
POSTGRES_DB="bevietnam"
POSTGRES_USER="bevietnam"
POSTGRES_PASSWORD=""
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="5432"

# MinIO capture storage. Blank ACCESS/SECRET keys = use existing .env or generate.
AUTO_MINIO="1"
MINIO_ENDPOINT="http://127.0.0.1:9000"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET="bevietnam-captures"
MINIO_CONSOLE_PORT="9001"

# AI/vLLM. vLLM uses port 8010 to avoid Backend port 8000.
HF_TOKEN=""
VLLM_API_KEY=""
VLLM_HOST="127.0.0.1"
VLLM_PORT="8010"
VLLM_MODEL="Qwen/Qwen2.5-14B-Instruct"
VLLM_SERVED_MODEL_NAME="qwen2.5-14b-instruct"
VLLM_DTYPE="bfloat16"
VLLM_MAX_MODEL_LEN="16384"
VLLM_GPU_MEMORY_UTILIZATION="0.92"
VLLM_ENABLE_PREFIX_CACHING="1"
VLLM_VERSION="0.8.5"

# Optional AI tracing/report.
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="BeVietnam"

# Service ports.
BACKEND_HOST="0.0.0.0"
BACKEND_PORT="8000"
AI_HOST="0.0.0.0"
AI_PORT="8001"

# Runner behavior.
START_VLLM="1"
START_VLLM_TUNNEL="0"  # this script owns cloudflared so vm_start should not.
TAIL_LOGS="1"

# ── Helpers ──────────────────────────────────────────────────────────────────
log() {
  printf '[bevietnam-setup] %s\n' "$*"
}

die() {
  printf '[bevietnam-setup] ERROR: %s\n' "$*" >&2
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

random_hex() {
  local bytes="${1:-24}"
  if command_exists openssl; then
    openssl rand -hex "$bytes"
  else
    python3 - "$bytes" <<'PY'
import secrets
import sys

print(secrets.token_hex(int(sys.argv[1])))
PY
  fi
}

existing_env_value() {
  local file="$1"
  local key="$2"
  [[ -f "$file" ]] || return 0
  grep -E "^${key}=" "$file" | tail -n 1 | cut -d= -f2- || true
}

require_value() {
  local name="$1"
  local value="$2"
  [[ -n "$value" ]] || die "$name is required. Fill it in scripts/vm_full_setup.local.sh before running."
}

url_quote() {
  python3 - "$1" <<'PY'
import sys
from urllib.parse import quote

print(quote(sys.argv[1], safe=""))
PY
}

install_cloudflared() {
  if command_exists cloudflared; then
    log "cloudflared already installed: $(cloudflared --version)"
    return
  fi

  log "Installing cloudflared"
  curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg \
    | sudo tee /usr/share/keyrings/cloudflare-main.gpg >/dev/null
  echo "deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared any main" \
    | sudo tee /etc/apt/sources.list.d/cloudflared.list >/dev/null
  sudo apt-get update
  sudo apt-get install -y cloudflared
}

write_root_env() {
  local env_file="$PROJECT_ROOT/.env"
  local existing_secret existing_pg_password quoted_user quoted_password quoted_db database_url
  local existing_minio_access existing_minio_secret

  existing_secret="$(existing_env_value "$env_file" SECRET_KEY)"
  existing_pg_password="$(existing_env_value "$env_file" POSTGRES_PASSWORD)"
  existing_minio_access="$(existing_env_value "$env_file" MINIO_ACCESS_KEY)"
  existing_minio_secret="$(existing_env_value "$env_file" MINIO_SECRET_KEY)"

  [[ -n "$SECRET_KEY" ]] || SECRET_KEY="$existing_secret"
  [[ -n "$SECRET_KEY" && "$SECRET_KEY" != "dev-only-change-me-in-production-32-bytes-minimum" ]] || SECRET_KEY="$(random_hex 32)"

  [[ -n "$POSTGRES_PASSWORD" ]] || POSTGRES_PASSWORD="$existing_pg_password"
  [[ -n "$POSTGRES_PASSWORD" && "$POSTGRES_PASSWORD" != "change-me" ]] || POSTGRES_PASSWORD="$(random_hex 18)"

  [[ -n "$MINIO_ACCESS_KEY" ]] || MINIO_ACCESS_KEY="$existing_minio_access"
  [[ -n "$MINIO_ACCESS_KEY" ]] || MINIO_ACCESS_KEY="$(random_hex 12)"
  [[ -n "$MINIO_SECRET_KEY" ]] || MINIO_SECRET_KEY="$existing_minio_secret"
  [[ -n "$MINIO_SECRET_KEY" ]] || MINIO_SECRET_KEY="$(random_hex 24)"

  quoted_user="$(url_quote "$POSTGRES_USER")"
  quoted_password="$(url_quote "$POSTGRES_PASSWORD")"
  quoted_db="$(url_quote "$POSTGRES_DB")"
  database_url="postgresql+asyncpg://${quoted_user}:${quoted_password}@${POSTGRES_HOST}:${POSTGRES_PORT}/${quoted_db}"

  log "Writing root .env"
  cat > "$env_file" <<ENV
# Generated by scripts/vm_full_setup.local.sh. Do not commit.
PROJECT_NAME=Tourism App API
VERSION=0.1.0
AI_CORE_BASE_URL=http://localhost:${AI_PORT}
AI_CORE_TIMEOUT=300
AI_CORE_USE_MOCK=false
QUESTION_POOL_PATH=data/question_pool.json

GOONG_API_KEY=${GOONG_API_KEY}
GOONG_BASE_URL=https://rsapi.goong.io
GOONG_TIMEOUT=10
OPENWEATHER_API_KEY=${OPENWEATHER_API_KEY}
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_TIMEOUT=10

DATABASE_URL=${database_url}
AUTO_POSTGRES=1
POSTGRES_DB=${POSTGRES_DB}
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_HOST=${POSTGRES_HOST}
POSTGRES_PORT=${POSTGRES_PORT}

SECRET_KEY=${SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

AUTO_MINIO=${AUTO_MINIO}
MINIO_ENDPOINT=${MINIO_ENDPOINT}
MINIO_ACCESS_KEY=${MINIO_ACCESS_KEY}
MINIO_SECRET_KEY=${MINIO_SECRET_KEY}
MINIO_BUCKET=${MINIO_BUCKET}
MINIO_CONSOLE_PORT=${MINIO_CONSOLE_PORT}

LLM_PROVIDER=vllm
VLLM_BASE_URL=http://127.0.0.1:${VLLM_PORT}/v1
VLLM_MODEL=${VLLM_SERVED_MODEL_NAME}
VLLM_API_KEY=${VLLM_API_KEY}
VLLM_VISION_BASE_URL=https://${CF_HOSTNAME}/vision/v1
VLLM_VISION_MODEL=qwen2.5-vl-7b

HF_TOKEN=${HF_TOKEN}
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PATH=/tmp/bevietnam-qdrant
QDRANT_CLUSTER_ENDPOINT=
QDRANT_API_KEY=
QDRANT_COLLECTION=cultural_knowledge

LANGSMITH_TRACING=${LANGSMITH_TRACING}
LANGSMITH_API_KEY=${LANGSMITH_API_KEY}
LANGSMITH_PROJECT=${LANGSMITH_PROJECT}

BACKEND_HOST=${BACKEND_HOST}
BACKEND_PORT=${BACKEND_PORT}
AI_HOST=${AI_HOST}
AI_PORT=${AI_PORT}
RUN_MIGRATIONS=1
INSTALL_DEPS=auto
AUTO_APT_INSTALL=1
START_VLLM=${START_VLLM}
START_VLLM_TUNNEL=${START_VLLM_TUNNEL}
ENV
  chmod 600 "$env_file"
}

write_vllm_env() {
  local env_file="$PROJECT_ROOT/vllm_hosting/.env"

  log "Writing vllm_hosting/.env"
  cat > "$env_file" <<ENV
# Generated by scripts/vm_full_setup.local.sh. Do not commit.
VLLM_MODEL=${VLLM_MODEL}
VLLM_SERVED_MODEL_NAME=${VLLM_SERVED_MODEL_NAME}
VLLM_DTYPE=${VLLM_DTYPE}
VLLM_MAX_MODEL_LEN=${VLLM_MAX_MODEL_LEN}
VLLM_GPU_MEMORY_UTILIZATION=${VLLM_GPU_MEMORY_UTILIZATION}
VLLM_ENABLE_PREFIX_CACHING=${VLLM_ENABLE_PREFIX_CACHING}

VLLM_HOST=${VLLM_HOST}
VLLM_PORT=${VLLM_PORT}
VLLM_API_KEY=${VLLM_API_KEY}
VLLM_VERSION=${VLLM_VERSION}

HF_TOKEN=${HF_TOKEN}

CF_HOSTNAME=${CF_HOSTNAME}
CF_TUNNEL_ID=${CF_TUNNEL_ID}
CF_ACCOUNT_TAG=${CF_ACCOUNT_TAG}
CF_TUNNEL_SECRET=${CF_TUNNEL_SECRET}
ENV
  chmod 600 "$env_file"
}

write_cloudflared_config() {
  local cf_dir="$HOME/.cloudflared"
  local cred_file="$cf_dir/$CF_TUNNEL_ID.json"
  local config_file="$cf_dir/config.yml"

  require_value "CF_HOSTNAME" "$CF_HOSTNAME"
  require_value "CF_TUNNEL_ID" "$CF_TUNNEL_ID"
  require_value "CF_ACCOUNT_TAG" "$CF_ACCOUNT_TAG"
  require_value "CF_TUNNEL_SECRET" "$CF_TUNNEL_SECRET"

  mkdir -p "$cf_dir"

  log "Writing cloudflared credentials"
  cat > "$cred_file" <<JSON
{
  "AccountTag": "$CF_ACCOUNT_TAG",
  "TunnelSecret": "$CF_TUNNEL_SECRET",
  "TunnelID": "$CF_TUNNEL_ID",
  "Endpoint": ""
}
JSON
  chmod 600 "$cred_file"

  log "Writing cloudflared config"
  if [[ "$CLOUDFLARED_ROUTE_VLLM_PATHS" == "1" ]]; then
    cat > "$config_file" <<YAML
tunnel: $CF_TUNNEL_ID
credentials-file: $cred_file

ingress:
  - hostname: $CF_HOSTNAME
    path: /v1/*
    service: http://127.0.0.1:${VLLM_PORT}
  - hostname: $CF_HOSTNAME
    path: /vision/v1/*
    service: http://127.0.0.1:${VLLM_PORT}
  - hostname: $CF_HOSTNAME
    service: $CLOUDFLARED_SERVICE_URL
  - service: http_status:404
YAML
  else
    cat > "$config_file" <<YAML
tunnel: $CF_TUNNEL_ID
credentials-file: $cred_file

ingress:
  - hostname: $CF_HOSTNAME
    service: $CLOUDFLARED_SERVICE_URL
  - service: http_status:404
YAML
  fi
  chmod 600 "$config_file"
}

start_cloudflared() {
  local pid_file="$PROJECT_ROOT/.run/cloudflared.pid"
  local log_file="$PROJECT_ROOT/logs/cloudflared.log"

  mkdir -p "$PROJECT_ROOT/.run" "$PROJECT_ROOT/logs"

  if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
    log "cloudflared already running pid=$(cat "$pid_file")"
    return
  fi

  log "Starting cloudflared tunnel"
  setsid cloudflared tunnel --config "$HOME/.cloudflared/config.yml" run "$CF_TUNNEL_ID" \
    >> "$log_file" 2>&1 < /dev/null &
  echo "$!" > "$pid_file"
}

main() {
  [[ -d "$PROJECT_ROOT" ]] || die "PROJECT_ROOT not found: $PROJECT_ROOT"
  cd "$PROJECT_ROOT"

  require_value "HF_TOKEN" "$HF_TOKEN"

  mkdir -p "$PROJECT_ROOT/logs" "$PROJECT_ROOT/.run"
  write_root_env
  write_vllm_env
  install_cloudflared
  write_cloudflared_config

  if [[ "$START_VLLM" == "1" ]]; then
    log "Bootstrapping vLLM dependencies"
    (cd "$PROJECT_ROOT/vllm_hosting" && bash bootstrap.sh --no-launch)
  fi

  log "Starting BeVietnam services"
  bash "$PROJECT_ROOT/scripts/vm_start.sh" start

  start_cloudflared

  log "Done."
  log "Backend public URL: https://${CF_HOSTNAME}/docs"
  log "Backend local URL : http://127.0.0.1:${BACKEND_PORT}/docs"
  log "AI local health   : http://127.0.0.1:${AI_PORT}/health"
  log "vLLM local models : http://127.0.0.1:${VLLM_PORT}/v1/models"

  if [[ "$TAIL_LOGS" == "1" ]]; then
    mkdir -p "$PROJECT_ROOT/logs"
    touch "$PROJECT_ROOT/logs/backend.log" \
      "$PROJECT_ROOT/logs/ai-core.log" \
      "$PROJECT_ROOT/logs/cloudflared.log" \
      "$PROJECT_ROOT/logs/vllm.log"
    log "Tailing logs. Ctrl+C stops tailing; services keep running."
    exec tail -f \
      "$PROJECT_ROOT/logs/backend.log" \
      "$PROJECT_ROOT/logs/ai-core.log" \
      "$PROJECT_ROOT/logs/cloudflared.log" \
      "$PROJECT_ROOT/logs/vllm.log"
  fi
}

main "$@"
