# Copy to scripts/vm_secrets.env, fill real values, then scp it to the VM.
# scripts/vm_secrets.env is gitignored. Never commit the real file.

# Backend / AI service
PROJECT_NAME=Tourism App API
VERSION=0.1.0
AI_CORE_BASE_URL=http://localhost:8001
AI_CORE_TIMEOUT=300
AI_CORE_USE_MOCK=false
SECRET_KEY=

# Backend integrations
GOONG_API_KEY=
OPENWEATHER_API_KEY=

# Local PostgreSQL. POSTGRES_PASSWORD and DATABASE_URL can be generated.
AUTO_POSTGRES=1
POSTGRES_DB=bevietnam
POSTGRES_USER=bevietnam
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=

# MinIO capture storage. Blank ACCESS/SECRET keys are auto-generated.
AUTO_MINIO=1
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=bevietnam-captures
MINIO_CONSOLE_PORT=9001

# AI provider
LLM_PROVIDER=vllm
ROOT_VLLM_BASE_URL=http://127.0.0.1:8010/v1
ROOT_VLLM_MODEL=qwen2.5-14b-instruct
VLLM_API_KEY=
VLLM_VISION_BASE_URL=https://api.iamphuckhang.dev/vision/v1
VLLM_VISION_MODEL=qwen2.5-vl-7b

# Retrieval / embeddings
HF_TOKEN=
QDRANT_PATH=/tmp/bevietnam-qdrant
QDRANT_CLUSTER_ENDPOINT=
QDRANT_API_KEY=

# Optional tracing for AI report/demo
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=BeVietnam

# VM runner
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
AI_HOST=0.0.0.0
AI_PORT=8001
RUN_MIGRATIONS=1
INSTALL_DEPS=auto
AUTO_APT_INSTALL=1
START_VLLM=1
START_VLLM_TUNNEL=1

# vLLM hosting. Use 8010 to avoid backend port 8000 conflict.
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
VLLM_SERVED_MODEL_NAME=qwen2.5-14b-instruct
VLLM_DTYPE=bfloat16
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_ENABLE_PREFIX_CACHING=1
VLLM_HOST=127.0.0.1
VLLM_PORT=8010
VLLM_VERSION=0.8.5

# Cloudflare tunnel for vLLM
CF_HOSTNAME=api.iamphuckhang.dev
CF_TUNNEL_ID=
CF_ACCOUNT_TAG=
CF_TUNNEL_SECRET=
