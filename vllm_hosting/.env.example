# vllm_hosting configuration — copy to .env and fill in secrets.
# .env is gitignored; never commit real tokens / tunnel secrets.

# ── Model ─────────────────────────────────────────────────────────────────────
# Qwen2.5-14B-Instruct: strong Vietnamese + JSON, bf16 fits an L40 (48 GB).
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
# Name clients use in the OpenAI "model" field (alias for the served model).
VLLM_SERVED_MODEL_NAME=qwen2.5-14b-instruct
VLLM_DTYPE=bfloat16
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_MEMORY_UTILIZATION=0.92
# Prefix caching reuses the KV cache for shared system prompts (big win for the
# book-ingestion workload that sends the same system prompt for every chunk).
VLLM_ENABLE_PREFIX_CACHING=1

# ── Serving ───────────────────────────────────────────────────────────────────
# Bind to loopback only; cloudflared connects locally, nothing is exposed on the
# VM's public interface.
VLLM_HOST=127.0.0.1
VLLM_PORT=8000
# Leave empty for an OPEN endpoint. Set a value to require
# `Authorization: Bearer <key>` on every request.
VLLM_API_KEY=

# vLLM version proven on L40 / Thundercompute with cloudflared.
VLLM_VERSION=0.8.5

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for gated models (LLaMA etc.); harmless for open models.
HF_TOKEN=hf_xxx

# ── Cloudflare tunnel "vllm" → api.iamphuckhang.dev ───────────────────────────
# From the cloudflared tunnel you already created. The DNS route
# (api.iamphuckhang.dev → <id>.cfargotunnel.com) must already exist in the
# Cloudflare dashboard — this stack does not create it.
CF_HOSTNAME=api.iamphuckhang.dev
CF_TUNNEL_ID=8aba8569-c29f-48fb-acc9-41f0dfa6463a
CF_ACCOUNT_TAG=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_TUNNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
