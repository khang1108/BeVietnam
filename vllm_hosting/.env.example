# vllm_hosting configuration — copy to .env and fill in secrets.
# .env is gitignored; never commit real tokens / tunnel secrets.
#
# THREE vLLM backends (text + vision + embeddings) sit behind one nginx router,
# exposed through cloudflared at a single hostname. Clients pick the backend by
# URL path:
#   text   → https://$CF_HOSTNAME/v1          (unchanged — existing clients keep working)
#   vision → https://$CF_HOSTNAME/vision/v1
#   embed  → https://$CF_HOSTNAME/embed/v1
#
# Default layout = ONE L40 (48 GB) hosting all three. For TWO L40s, move the
# vision model to GPU 1 (VISION_GPU=1) and raise the util caps — see comments.

# ── TEXT model — generation (Trip Advisor explain, offline quest/post gen, Ask Huế)
# Qwen2.5-14B: strong Vietnamese + JSON. FP8 (~14 GB) leaves KV room next to the
# other models on a shared GPU. Use the non-FP8 build only with 2 GPUs.
TEXT_MODEL=Qwen/Qwen2.5-14B-Instruct-FP8
TEXT_SERVED_NAME=qwen2.5-14b-instruct
TEXT_PORT=8001
TEXT_GPU=0
TEXT_GPU_UTIL=0.32          # 1-GPU. With 2 GPUs (text alone on GPU0): 0.90
TEXT_MAX_LEN=8192
TEXT_DTYPE=auto             # FP8 checkpoint sets its own dtype; "auto" is safe

# ── VISION model — Capture Judge verdict + Lens (image vs task)
# Qwen2.5-VL-7B: best open VLM for OCR + scene match, reads Vietnamese signs/menus.
VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VISION_SERVED_NAME=qwen2.5-vl-7b
VISION_PORT=8002
VISION_GPU=0                # 1-GPU: keep 0. 2-GPU: set to 1 (vision owns GPU1)
VISION_GPU_UTIL=0.40        # 1-GPU. With 2 GPUs (vision alone on GPU1): 0.90
VISION_MAX_LEN=8192
VISION_DTYPE=bfloat16

# ── EMBED model — bge-m3 query embeddings.
# ONLY needed at runtime if Ask Huế free-text RAG is live. Trip Advisor + vision
# do not query it. Set EMBED_ENABLED=0 to skip it (embed the KB offline instead)
# and reclaim its GPU slot.
EMBED_ENABLED=1
EMBED_MODEL=BAAI/bge-m3
EMBED_SERVED_NAME=bge-m3
EMBED_PORT=8003
EMBED_GPU=0
EMBED_GPU_UTIL=0.10

# ── Router (nginx) — the ONLY port cloudflared exposes ────────────────────────
ROUTER_PORT=8000
# Bind backends + router to loopback; cloudflared connects locally.
BIND_HOST=127.0.0.1
# Leave empty for an OPEN endpoint. Set a value to require
# `Authorization: Bearer <key>` on every request (enforced by each vLLM backend).
VLLM_API_KEY=

# Prefix caching reuses the KV cache for shared system prompts (big win for the
# offline gen workloads that send the same system prompt every call).
VLLM_ENABLE_PREFIX_CACHING=1

# vLLM version proven on L40 / Thundercompute with cloudflared.
VLLM_VERSION=0.8.5

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for gated models; harmless for open ones.
HF_TOKEN=hf_xxx

# ── Cloudflare tunnel "vllm" → api.iamphuckhang.dev ───────────────────────────
# DNS route (api.iamphuckhang.dev → <id>.cfargotunnel.com) must already exist.
CF_HOSTNAME=api.iamphuckhang.dev
CF_TUNNEL_ID=8aba8569-c29f-48fb-acc9-41f0dfa6463a
CF_ACCOUNT_TAG=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CF_TUNNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
